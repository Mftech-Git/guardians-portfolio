# Ghost CMS Configuration
# After setting up Ghost, go to: http://localhost:2368/ghost/#/settings/integrations
# Create a new Custom Integration called "Portfolio"
# Copy the Content API Key here

VITE_GHOST_URL=http://localhost:2368
VITE_GHOST_CONTENT_KEY=your_content_api_key_here

# For production, set GHOST_URL to your actual domain
# VITE_GHOST_URL=https://blog.yourdomain.com
