{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/admin/*", "/uploads/*", "/logo.png", "/logo-animation.mp4", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.ico", "*.mp3", "*.yml", "*.pdf"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".mp3": "audio/mpeg",
    ".yml": "text/yaml",
    ".yaml": "text/yaml"
  }
}
